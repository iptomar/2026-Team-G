@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Esqueceu a sua palavra-passe?";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/forgot-password.css" />

<div class="page-header">
    <h1>Recuperar palavra-passe</h1>
    <p>Insira o seu email para receber as instruções de recuperação</p>
</div>

<div class="forgot-container">
    <div class="forgot-card">
        <div class="forgot-header">
            <h2>Enviar instruções</h2>
            <p>Vamos enviar um link para redefinir a sua palavra-passe</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-forgot">Enviar instruções</button>

            <div class="forgot-links">
                <a asp-page="./Login">Voltar ao Login</a>
                <a asp-page="./Register">Registar nova conta</a>
            </div>
        </form>
    </div>
</div>

<div class="forgot-footer">
    <p>© 2026 - Team_G - Privacidade</p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}