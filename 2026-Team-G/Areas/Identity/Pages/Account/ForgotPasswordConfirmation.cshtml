@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Link enviado";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/confirmation.css" />

<div class="page-header">
    <h1>Verifique o seu email</h1>
    <p>Enviamos um link para redefinir a sua palavra-passe</p>
</div>

<div class="confirmation-container">
    <div class="confirmation-card">
        <div class="icon-circle">
            <i class="bi bi-envelope-check-fill"></i>
        </div>

        <h2>Instruções enviadas!</h2>

        <p>Enviamos um email com um link para redefinir a sua palavra-passe.</p>

        <p class="text-muted small">
            Por favor, verifique a sua caixa de entrada e também a pasta de spam.
            O link é válido por 24 horas.
        </p>

        <div class="confirmation-links">
            <a asp-page="./Login" class="btn-login">Voltar ao Login</a>
            <a asp-page="./ResendEmailConfirmation" class="link-help">Não recebeu o email?</a>
        </div>
    </div>
</div>

<div class="confirmation-footer">
    <p>© 2026 - Team_G - Privacidade</p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}