@page
@model RegisterModel
@{
    ViewData["Title"] = "Registar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/registo.css" />

<div class="page-header">
    <h1>Criar nova conta</h1>
    <p>Registe-se para começar a criar e gerir os seus formulários</p>
</div>

<div class="register-container">
    <div class="register-card">
        <div class="register-header">
            <p>Preencha os dados abaixo para se registar</p>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="form-group">
                <label asp-for="Input.Username">Nome de Utilizador</label>
                <input asp-for="Input.Username" class="form-control" autocomplete="username" aria-required="true" placeholder="o_seu_username" />
                <span asp-validation-for="Input.Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="nome@exemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password">Palavra-passe</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="palavra-passe" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
                <small class="form-hint">A palavra-passe deve incluir pelo menos um número, uma letra maiúscula, uma letra minúscula e um caractere especial</small>
            </div>

            <div class="form-group">
                <label asp-for="Input.ConfirmPassword">Confirmar Palavra-passe</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="palavra-passe" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn-register">Registar</button>

            <div class="register-links">
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Já tem uma conta? Iniciar Sessão</a>
            </div>
        </form>
    </div>

    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
    {
        <div class="external-register-card">
            <div class="external-header">
                <h3>Use outro serviço para se registar</h3>
                <p>Registe-se usando uma conta externa</p>
            </div>
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                <div class="external-buttons">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn-external" name="provider" value="@provider.Name" title="Registe-se com a sua conta @provider.DisplayName">
                            @provider.DisplayName
                        </button>
                    }
                </div>
            </form>
        </div>
    }
</div>

<div class="register-footer">
    <p>© 2026 - Team_G - Privacidade</p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}