@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Redefinir palavra-passe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/reset-password.css" />

<div class="page-header">
    <h1>Redefinir palavra-passe</h1>
    <p>Crie uma nova palavra-passe para a sua conta</p>
</div>

<div class="reset-container">
    <div class="reset-card">
        <div class="reset-header">
            <h2>Nova palavra-passe</h2>
            <p>Escolha uma palavra-passe segura</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <input asp-for="Input.Code" type="hidden" />

            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="nome@exemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password">Nova palavra-passe</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="palavra-passe" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
                <small class="form-hint">A palavra-passe deve ter pelo menos 6 caracteres</small>
            </div>

            <div class="form-group">
                <label asp-for="Input.ConfirmPassword">Confirmar palavra-passe</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="confirmar palavra-passe" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-reset">Redefinir palavra-passe</button>

            <div class="reset-links">
                <a asp-page="./Login">Voltar ao Login</a>
            </div>
        </form>
    </div>
</div>

<div class="reset-footer">
    <p>© 2026 - Team_G - Privacidade</p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}