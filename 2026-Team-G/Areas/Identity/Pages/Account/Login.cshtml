@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar Sessão";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/User/login.css" />

<div class="page-header">
    <h1>Bem-vindo de volta!</h1>
    <p>Faça login para aceder à sua conta e gerir os seus formulários</p>
</div>

<div class="login-container">
    <div class="login-card">
       
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="form-group">
                <label asp-for="Input.Email">Nome de Utilizador ou Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="username ou email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password">Palavra-passe</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="palavra-passe" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="checkbox-group">
                <label asp-for="Input.RememberMe" class="checkbox-label">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                </label>
            </div>

            <button id="login-submit" type="submit" class="btn-login">Iniciar Sessão</button>

            <div class="login-links">
                <a id="forgot-password" asp-page="./ForgotPassword">Esqueceu a sua palavra-passe?</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Registar como novo utilizador</a>
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Reenviar email de confirmação</a>
            </div>
        </form>
    </div>

    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
    {
        <div class="external-login-card">
            <div class="external-header">
                <h3>Use outro serviço para iniciar sessão</h3>
            </div>
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                <div class="external-buttons">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn-external" name="provider" value="@provider.Name" title="Inicie sessão usando a sua conta @provider.DisplayName">
                            @provider.DisplayName
                        </button>
                    }
                </div>
            </form>
        </div>
    }
</div>

<div class="login-footer">
    <p>© 2026 - Team_G - Privacidade</p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}