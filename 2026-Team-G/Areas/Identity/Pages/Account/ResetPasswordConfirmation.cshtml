@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password redefinida";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/User/reset-password-confirmation.css" />

<div class="page-header">
    <h1>Palavra-passe alterada!</h1>
    <p>A sua palavra-passe foi redefinida com sucesso</p>
</div>

<div class="confirmation-container">
    <div class="confirmation-card">
        <div class="icon-circle">
            <i class="bi bi-check2-circle-fill"></i>
        </div>

        <h2>Sucesso!</h2>

        <p>A sua palavra-passe foi alterada com sucesso.</p>

        <p class="text-muted small">
            Agora pode iniciar sessão com a sua nova palavra-passe.
        </p>

        <div class="confirmation-links">
            <a asp-page="./Login" class="btn-login">Iniciar Sessão</a>
        </div>
    </div>
</div>

<div class="confirmation-footer">
    <p>© 2026 - Team_G - Privacidade</p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}