@model _2026_Team_G.Models.Formulario
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

<style>
    :root {
        --ipt-green: #7cb13b;
        --ipt-green-hover: #6a9c30;
        --fb-bg: #f8f9fa;
        --fb-surface: #ffffff;
        --fb-border: #e9ecef;
        --fb-text: #2b2d42;
        --fb-text-muted: #6c757d;
    }

    body {
        background-color: var(--fb-bg);
    }

    .form-container {
        max-width: 800px;
        margin: 40px auto;
        background: var(--fb-surface);
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        border: 1px solid var(--fb-border);
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, #f4faeb 0%, #ffffff 100%);
        padding: 40px;
        border-bottom: 1px solid rgba(124, 177, 59, 0.15);
        position: relative;
    }

    .form-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background-color: var(--ipt-green);
    }

    .form-header h1 {
        font-family: 'Outfit', 'Inter', sans-serif;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 12px;
        letter-spacing: -0.5px;
    }

    .form-header p {
        color: var(--fb-text-muted);
        font-size: 1.1rem;
        margin-bottom: 0;
        line-height: 1.6;
    }

    .form-body {
        padding: 40px;
    }

    .field-wrapper {
        margin-bottom: 24px;
    }

    .field-label {
        font-weight: 600;
        color: var(--fb-text);
        margin-bottom: 8px;
        display: block;
        font-size: 0.95rem;
    }

    .field-required {
        color: #ef4444;
        margin-left: 4px;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 12px 16px;
        border: 1.5px solid var(--fb-border);
        transition: all 0.2s ease;
        color: var(--fb-text);
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--ipt-green);
        box-shadow: 0 0 0 4px rgba(124, 177, 59, 0.15);
        outline: none;
    }

    .form-control.is-invalid, .form-select.is-invalid {
        border-color: #ef4444;
        background-image: none;
    }

    .form-control.is-invalid:focus, .form-select.is-invalid:focus {
        box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.15);
    }

    .invalid-feedback {
        color: #ef4444;
        font-size: 0.85rem;
        margin-top: 6px;
        display: block;
        font-weight: 500;
    }

    .form-check {
        padding-left: 28px;
    }

    .form-check-input {
        width: 1.25em;
        height: 1.25em;
        margin-left: -28px;
        margin-top: 0.15em;
        border-radius: 4px;
        border: 1.5px solid var(--fb-border);
    }

    .form-check-input:checked {
        background-color: var(--ipt-green);
        border-color: var(--ipt-green);
    }

    .form-check-input:focus {
        box-shadow: 0 0 0 4px rgba(124, 177, 59, 0.15);
        border-color: var(--ipt-green);
    }

    .form-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 16px;
        margin-top: 40px;
        padding-top: 24px;
        border-top: 1px solid var(--fb-border);
    }

    .btn-cancel {
        background-color: transparent;
        color: var(--fb-text-muted);
        border: 1.5px solid var(--fb-border);
        border-radius: 10px;
        padding: 12px 24px;
        font-weight: 600;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .btn-cancel:hover {
        background-color: #f1f5f9;
        color: var(--fb-text);
        border-color: #cbd5e1;
    }

    .btn-submit {
        background-color: var(--ipt-green);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px 32px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s ease;
    }

    .btn-submit:hover {
        background-color: var(--ipt-green-hover);
        transform: translateY(-1px);
    }

    .title-field {
        border-bottom: 2px solid var(--fb-border);
        padding-bottom: 8px;
        margin-top: 32px;
        margin-bottom: 16px;
    }

    .title-field h3 {
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 4px;
    }
</style>

<div class="container pb-5">
    <div class="form-container">
        <div class="form-header">
            <h1>@Model.Title</h1>
            <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "Por favor, preencha os campos abaixo." : Model.Description)</p>
        </div>

        <form asp-action="Submeter" asp-route-id="@Model.Id" method="post" class="form-body">
            @Html.AntiForgeryToken()

            <div class="row">
                @foreach (var field in Model.Fields)
                {
                    var widthClass = "col-12";
                    if (field.Width == "75%") { widthClass = "col-md-9 col-12"; }
                    else if (field.Width == "50%") { widthClass = "col-md-6 col-12"; }
                    else if (field.Width == "33%") { widthClass = "col-md-4 col-12"; }
                    else if (field.Width == "25%") { widthClass = "col-md-3 col-12"; }

                    var hasError = ViewData.ModelState[field.FieldId]?.Errors.Any() ?? false;
                    var errorMsg = hasError ? ViewData.ModelState[field.FieldId].Errors.First().ErrorMessage : "";
                    
                    // Obter valor anterior submetido em caso de erro de validação
                    var prevValue = Context.Request.HasFormContentType ? Context.Request.Form[field.FieldId].ToString() : "";

                    <div class="@widthClass field-wrapper">
                        @if (field.Type == "title")
                        {
                            <div class="title-field">
                                <h3>@field.Label</h3>
                                @if (!string.IsNullOrEmpty(field.Placeholder))
                                {
                                    <p class="text-muted small mb-0">@field.Placeholder</p>
                                }
                            </div>
                        }
                        else if (field.Type == "button")
                        {
                            <button type="button" class="btn btn-outline-secondary mt-2">@field.Label</button>
                        }
                        else
                        {
                            <label class="field-label" for="@field.FieldId">
                                @field.Label
                                @if (field.IsRequired)
                                {
                                    <span class="field-required">*</span>
                                }
                            </label>

                            @if (field.Type == "text")
                            {
                                <input type="text" name="@field.FieldId" id="@field.FieldId" 
                                       class="form-control @(hasError ? "is-invalid" : "")" 
                                       placeholder="@field.Placeholder" 
                                       @(field.IsRequired ? "required" : "") 
                                       value="@prevValue" />
                            }
                            else if (field.Type == "textarea")
                            {
                                <textarea name="@field.FieldId" id="@field.FieldId" 
                                          class="form-control @(hasError ? "is-invalid" : "")" 
                                          placeholder="@field.Placeholder" 
                                          rows="4"
                                          @(field.IsRequired ? "required" : "")>@prevValue</textarea>
                            }
                            else if (field.Type == "number")
                            {
                                <input type="number" name="@field.FieldId" id="@field.FieldId" 
                                       class="form-control @(hasError ? "is-invalid" : "")" 
                                       placeholder="@field.Placeholder" 
                                       @(field.IsRequired ? "required" : "") 
                                       value="@prevValue" />
                            }
                            else if (field.Type == "date")
                            {
                                <input type="date" name="@field.FieldId" id="@field.FieldId" 
                                       class="form-control @(hasError ? "is-invalid" : "")" 
                                       @(field.IsRequired ? "required" : "") 
                                       value="@prevValue" />
                            }
                            else if (field.Type == "select")
                            {
                                <select name="@field.FieldId" id="@field.FieldId" 
                                        class="form-select @(hasError ? "is-invalid" : "")" 
                                        @(field.IsRequired ? "required" : "")>
                                    <option value="">-- Selecione uma opção --</option>
                                    @if (!string.IsNullOrEmpty(field.Options))
                                    {
                                        foreach (var opt in field.Options.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            var optTrim = opt.Trim();
                                            var isSelected = prevValue == optTrim;
                                            <option value="@optTrim" selected="@isSelected">@optTrim</option>
                                        }
                                    }
                                </select>
                            }
                            else if (field.Type == "checkbox")
                            {
                                var isChecked = prevValue == "true" || prevValue == "on";
                                <div class="form-check">
                                    <input type="checkbox" name="@field.FieldId" id="@field.FieldId" value="true"
                                           class="form-check-input @(hasError ? "is-invalid" : "")" 
                                           @(isChecked ? "checked" : "") />
                                    <label class="form-check-label text-muted" for="@field.FieldId">
                                        @(string.IsNullOrEmpty(field.Placeholder) ? "Confirmar seleção" : field.Placeholder)
                                    </label>
                                </div>
                            }
                            else if (field.Type == "radio")
                            {
                                @if (!string.IsNullOrEmpty(field.Options))
                                {
                                    foreach (var opt in field.Options.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        var optTrim = opt.Trim();
                                        var isRadioChecked = prevValue == optTrim;
                                        <div class="form-check">
                                            <input type="radio" name="@field.FieldId" id="@(field.FieldId + "_" + optTrim)" value="@optTrim"
                                                   class="form-check-input @(hasError ? "is-invalid" : "")" 
                                                   @(isRadioChecked ? "checked" : "") />
                                            <label class="form-check-label text-muted" for="@(field.FieldId + "_" + optTrim)">
                                                @optTrim
                                            </label>
                                        </div>
                                    }
                                }
                            }

                            @if (hasError)
                            {
                                <span class="invalid-feedback">@errorMsg</span>
                            }
                        }
                    </div>
                }
            </div>

            <div class="form-actions">
                <a asp-action="Disponiveis" class="btn-cancel">Cancelar</a>
                <button type="submit" class="btn-submit">
                    <i class="bi bi-send"></i>
                    Submeter Respostas
                </button>
            </div>
        </form>
    </div>
</div>
