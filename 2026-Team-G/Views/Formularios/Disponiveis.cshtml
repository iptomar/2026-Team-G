@model IEnumerable<_2026_Team_G.Models.Formulario>
@{
    ViewData["Title"] = "Formulários Disponíveis";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

<link rel="stylesheet" href="~/css/formulariosdisponiveis.css" asp-append-version="true" />

<div class="container pb-5">
    <div class="page-header">
        <h1>Formulários Disponíveis</h1>
        <p>Selecione um dos formulários ativos listados abaixo para submeter as suas respostas.</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="forms-grid">
            @foreach (var form in Model)
            {
                <div class="form-card">
                    <div>
                        <div class="form-title">@form.Title</div>
                        <div class="form-description">
                            @(string.IsNullOrWhiteSpace(form.Description) ? "Sem descrição disponível." : form.Description)
                        </div>
                    </div>
                    <div>
                        <div class="form-meta">
                            <div>
                                <i class="bi bi-list-task me-1"></i>
                                @form.Fields?.Count campos
                            </div>
                            <div>
                                <i class="bi bi-shield-check me-1"></i>
                                Ativo
                            </div>
                        </div>
                        <a asp-action="Preencher" asp-route-id="@form.Id" class="btn-fill">
                            <i class="bi bi-pencil-square"></i>
                            Preencher Formulário
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-file-earmark-lock2"></i>
            <h3>Nenhum formulário ativo</h3>
            <p>Atualmente não existem formulários disponíveis para preenchimento. Por favor, tente mais tarde.</p>
        </div>
    }
</div>
