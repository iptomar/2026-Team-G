@model _2026_Team_G.Models.Submissao
@{
    ViewData["Title"] = "Detalhes da Resposta";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var responsesByRow = Model.Respostas
        .Where(r => r.FormFieldModel != null)
        .GroupBy(r => r.FormFieldModel.Options ?? "0")
        .OrderBy(g => g.Min(r => r.FormFieldModel.OrderIndex))
        .ToList();
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

<link rel="stylesheet" href="~/css/Formularios/detalhessubmissao.css" asp-append-version="true" />

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-3 no-print">
        <a asp-controller="Home" asp-action="HistoricoFormulariosUtilizador" class="btn-back">
            <i class="bi bi-arrow-left"></i> Voltar ao Histórico
        </a>
        <button onclick="window.print();" class="btn btn-ipt-green px-4 py-2 d-flex align-items-center gap-2">
            <i class="bi bi-printer-fill"></i> Imprimir
        </button>
        <a asp-action="ExportarPDF" asp-route-id="@Model.Id" class="btn btn-primary px-4 py-2 d-flex align-items-center gap-2">
            <i class="bi bi-file-earmark-pdf-fill"></i> Exportar PDF
        </a>
    </div>

    <div class="details-container">
        <div class="details-header">
            <h1 class="form-print-title">@Model.Formulario.Title</h1>
            <p class="no-print mb-0">Visualização das respostas submetidas pelo utilizador.</p>

            <div class="details-meta">
                <div class="meta-item">
                    <i class="bi bi-clock"></i>
                    <span>Submetido em: <strong>@Model.DataSubmissao.ToString("dd/MM/yyyy HH:mm")</strong></span>
                </div>
                <div class="meta-item">
                    <i class="bi bi-person"></i>
                    <span>Submetido por: <strong>@(Model.Utilizador?.UserName ?? "Utilizador")</strong></span>
                </div>
            </div>
        </div>

        <div class="details-body">
            @if (responsesByRow.Any())
            {
                foreach (var row in responsesByRow)
                {
                    var responsesInRow = row.OrderBy(r => r.FormFieldModel.OrderIndex).ToList();
                    var colSize = responsesInRow.Count switch
                    {
                        1 => "col-12",
                        2 => "col-6",
                        3 => "col-4",
                        4 => "col-3",
                        _ => "col"
                    };

                    <div class="row g-3 mb-3">
                        @foreach (var resposta in responsesInRow)
                        {
                            var tipo = resposta.FormFieldModel.Type?.Trim().ToLower() ?? "";

                            <div class="@colSize">
                                @if (tipo == "title")
                                {
                                    <div class="border-bottom pb-2 mt-3 mb-2">
                                        <h4 class="font-weight-bold mb-0 text-dark">@resposta.FormFieldModel.Label</h4>
                                    </div>
                                }
                                else if (tipo == "label")
                                {
                                    <p class="text-muted mb-0 fw-semibold">@resposta.FormFieldModel.Label</p>
                                }
                                else if (tipo == "button")
                                {
                                    <!-- Botões não precisam de ser impressos -->
                                }
                                else
                                {
                                    <div class="response-card">
                                        <span class="question-label">@resposta.FormFieldModel.Label</span>

                                        @if (tipo == "checkbox" || tipo == "check box" || tipo == "check box switch")
                                        {
                                            var isChecked = resposta.Valor == "true" || resposta.Valor == "on";
                                            <div class="answer-checkbox">
                                                <div class="req-checkbox-box @(isChecked ? "checked" : "")"></div>
                                                <span class="fw-semibold">
                                                    @(isChecked ? "Selecionado" : "Não Selecionado")
                                                </span>
                                            </div>
                                        }
                                        else
                                        {
                                            @if (string.IsNullOrWhiteSpace(resposta.Valor))
                                            {
                                                <div class="answer-value empty">
                                                    Não respondido / Em branco
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="answer-value">
                                                    @resposta.Valor
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="alert alert-warning">
                    Não existem respostas registadas para esta submissão.
                </div>
            }
        </div>
    </div>
</div>

