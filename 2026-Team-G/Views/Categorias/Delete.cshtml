@model _2026_Team_G.Models.Categoria

@{
    ViewData["Title"] = "Eliminar Categoria";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container pb-5">
    <div class="page-header">
        <h1>Eliminar Categoria</h1>
        <p>Confirme a remoção desta categoria antes de prosseguir.</p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h5>Tem a certeza que pretende eliminar esta categoria?</h5>

            <dl class="row mt-3">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Descrição</dt>
                <dd class="col-sm-9">@Model.Descricao</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                    <a asp-action="Index" class="btn btn-ipt-outline">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
