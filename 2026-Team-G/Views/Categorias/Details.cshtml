@model _2026_Team_G.Models.Categoria

@{
    ViewData["Title"] = "Detalhes da Categoria";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container pb-5">
    <div class="page-header">
        <h1>Detalhes da Categoria</h1>
        <p>Visualize os detalhes da categoria selecionada.</p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Descrição</dt>
                <dd class="col-sm-9">@Model.Descricao</dd>
            </dl>

            <div class="mt-3 d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-ipt-green">Editar</a>
                <a asp-action="Index" class="btn btn-ipt-outline">Voltar</a>
            </div>
        </div>
    </div>
</div>
