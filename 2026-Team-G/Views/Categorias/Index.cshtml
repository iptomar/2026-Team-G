@model IEnumerable<_2026_Team_G.Models.Categoria>

@{
    ViewData["Title"] = "Categorias";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container pb-5">
    <div class="page-header">
        <h1>Categorias</h1>
        <p>Gerencie as categorias usadas para agrupar e filtrar os formulários.</p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
                <div>
                    <h2 class="h5 mb-1">Lista de categorias</h2>
                    <p class="text-muted mb-0">Adicionar, editar ou remover categorias para organizar os formulários do website.</p>
                </div>
                <a asp-action="Create" class="btn btn-ipt-green">Nova Categoria</a>
            </div>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Descrição</th>
                            <th class="text-end" style="width: 240px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.Descricao)</td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a class="btn btn-sm btn-ipt-outline" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                                        <a class="btn btn-sm btn-ipt-outline" asp-action="Details" asp-route-id="@item.Id">Ver</a>
                                        <a class="btn btn-sm btn-ipt-outline text-danger" asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
