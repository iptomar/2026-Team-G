@{
    ViewData["Title"] = "Construtor de Formulários";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

<div class="container-fluid py-4 bg-light" style="min-height: calc(100vh - 60px);">
    <!-- Header Area -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-layout-wtf text-primary me-2"></i>Construtor de Formulários
            </h2>
            <p class="text-secondary mb-0">Arraste e solte elementos para criar um formulário incrível num instante.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary fw-semibold">
                <i class="bi bi-eye me-1"></i> Pré-visualizar
            </button>
            <button class="btn btn-primary fw-semibold shadow-sm" id="btnSaveForm">
                <i class="bi bi-cloud-arrow-up me-1"></i> Guardar Formulário
            </button>
        </div>
    </div>

    <!-- Main Workspace -->
    <div class="row g-4" style="min-height: 70vh;">
        <!-- Sidebar - Toolbox -->
        <div class="col-lg-3 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-grid-1x2 text-primary me-2"></i> Componentes</h5>
                </div>
                <div class="card-body overflow-auto" id="builderToolbox" style="max-height: 70vh;">
                    
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="text" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-input-cursor-text text-primary fs-5"></i><span class="fw-medium text-secondary">Texto Curto</span>
                        </div>
                    </div>
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="textarea" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-card-text text-primary fs-5"></i><span class="fw-medium text-secondary">Texto Longo</span>
                        </div>
                    </div>
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="number" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-123 text-primary fs-5"></i><span class="fw-medium text-secondary">Numérico</span>
                        </div>
                    </div>
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="email" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-envelope-at text-primary fs-5"></i><span class="fw-medium text-secondary">E-mail</span>
                        </div>
                    </div>
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="select" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-menu-button-wide text-primary fs-5"></i><span class="fw-medium text-secondary">Lista Suspensa</span>
                        </div>
                    </div>
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="checkbox" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-check-all text-primary fs-5"></i><span class="fw-medium text-secondary">Caixas de Seleção</span>
                        </div>
                    </div>
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="radio" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-ui-radios text-primary fs-5"></i><span class="fw-medium text-secondary">Escolha Única</span>
                        </div>
                    </div>
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="date" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-calendar-event text-primary fs-5"></i><span class="fw-medium text-secondary">Seletor de Data</span>
                        </div>
                    </div>
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="title" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-type-h1 text-primary fs-5"></i><span class="fw-medium text-secondary">Título / Secção</span>
                        </div>
                    </div>
                    <div class="card mb-3 border bg-white shadow-sm toolbox-item" data-type="button" style="cursor: grab;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <i class="bi bi-mouse2 text-primary fs-5"></i><span class="fw-medium text-secondary">Botão de Ação</span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Center - Dropzone -->
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-window-sidebar text-primary me-2"></i> Tela de Desenho</h5>
                </div>
                <div class="card-body d-flex flex-column h-100">
                    <div class="flex-grow-1 border border-2 rounded bg-light p-4 overflow-auto position-relative" id="formDropzone" style="border-style: dashed !important; border-color: #dee2e6 !important; min-height: 500px; max-height: 70vh;">
                        
                        <div id="dropzoneEmptyState" class="position-absolute top-50 start-50 translate-middle text-center w-100" style="pointer-events: none;">
                            <i class="bi bi-plus-square-dotted text-secondary opacity-50" style="font-size: 3rem;"></i>
                            <h5 class="text-secondary mt-3 opacity-75">Arraste os componentes para aqui</h5>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <!-- Right sidebar - Properties Panel -->
        <div class="col-lg-3 col-md-12 d-none" id="propertiesPanelContainer">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-4 pb-2 text-end text-lg-start">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-sliders2-vertical text-primary me-2"></i> Propriedades</h5>
                </div>
                <div class="card-body overflow-auto" style="max-height: 70vh;">
                    <form id="propForm">
                        <div class="mb-4">
                            <label class="form-label text-uppercase text-secondary fw-semibold small">Rótulo (Label)</label>
                            <input type="text" class="form-control border-secondary-subtle" id="propLabel" />
                        </div>
                        <div class="mb-4" id="propPlaceholderContainer">
                            <label class="form-label text-uppercase text-secondary fw-semibold small">Texto Fantasma</label>
                            <input type="text" class="form-control border-secondary-subtle" id="propPlaceholder" />
                        </div>
                        <div class="mb-4 p-3 bg-light rounded border border-light-subtle">
                            <div class="form-check form-switch d-flex align-items-center justify-content-between m-0 p-0">
                                <label class="form-check-label fw-bold flex-grow-1 text-dark m-0" for="propRequired">Obrigatório</label>
                                <input class="form-check-input m-0 float-none" type="checkbox" id="propRequired" role="switch" style="width: 2.5em; height: 1.25em; cursor: pointer;">
                            </div>
                        </div>
                        <div class="mb-4" id="propOptionsContainer" style="display: none;">
                            <label class="form-label text-uppercase text-secondary fw-semibold small">Opções</label>
                            <div class="text-secondary small mb-2">Separe as opções com vírgula</div>
                            <textarea class="form-control border-secondary-subtle" id="propOptions" rows="4" style="resize:none;"></textarea>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Importing Sortable.js for smooth Drag & Drop functionality -->
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            
        function generateId() {
        return 'field_' + Math.random().toString(36).substr(2, 9);
        }

        // Initialization logic with Sortable
        new Sortable(document.getElementById('builderToolbox'), {
        group: {
        name: 'shared',
        pull: 'clone',
        put: false
        },
        sort: false,
        animation: 150
        });

        const dropzone = document.getElementById('formDropzone');
        const propertiesContainer = document.getElementById('propertiesPanelContainer');
        const emptyState = document.getElementById('dropzoneEmptyState');
        let currentSelected = null;

        new Sortable(dropzone, {
        group: 'shared',
        animation: 200,
        ghostClass: 'opacity-50',
        onAdd: function (evt) {
        const item = evt.item;
        const type = item.getAttribute('data-type');
                    
        const newEl = document.createElement('div');
        // Completely custom CSS replaced by native Bootstrap Utility classes
        newEl.className = 'form-item card border-secondary-subtle mb-3 bg-white position-relative shadow-sm transition-all';
        newEl.id = generateId();
        newEl.setAttribute('data-type', type);
        newEl.style.cursor = 'pointer';

        const content = getHtmlTemplate(type);
        newEl.innerHTML = `
        <div class="position-absolute top-0 end-0 mt-2 me-2 d-none btn-actions" style="z-index: 10;">
        <button type="button" class="btn btn-sm btn-danger btn-delete shadow-sm rounded-circle px-2 py-1"><i class="bi bi-trash-fill" style="pointer-events:none;"></i></button>
        </div>
        <div class="card-body p-4 field-content">
        ${content}
        </div>
        `;

        if (emptyState) emptyState.style.display = 'none';

        item.parentNode.insertBefore(newEl, item);
        item.parentNode.removeChild(item);

        selectField(newEl);
        },
        onUpdate: function() {
        if (dropzone.querySelectorAll('.form-item').length > 0) {
        if (emptyState) emptyState.style.display = 'none';
        }
        },
        onRemove: function() {
        if (dropzone.querySelectorAll('.form-item').length === 0) {
        if (emptyState) emptyState.style.display = 'block';
        }
        }
        });

        // Hover effects simulated by native JS and standard Bootstrap classes
        dropzone.addEventListener('mouseover', function(e) {
        const field = e.target.closest('.form-item');
        if(field && field !== currentSelected) {
        field.classList.remove('border-secondary-subtle');
        field.classList.add('border-primary');
        field.querySelector('.btn-actions').classList.remove('d-none');
        }
        });

        dropzone.addEventListener('mouseout', function(e) {
        const field = e.target.closest('.form-item');
        if(field && field !== currentSelected) {
        field.classList.remove('border-primary');
        field.classList.add('border-secondary-subtle');
        field.querySelector('.btn-actions').classList.add('d-none');
        }
        });

        dropzone.addEventListener('click', function(e) {
        if(e.target.classList.contains('btn-delete') || e.target.closest('.btn-delete')) {
        const field = e.target.closest('.form-item');
        if(currentSelected === field) {
        unselectField();
        }
        field.remove();
                    
        if (dropzone.querySelectorAll('.form-item').length === 0) {
        if (emptyState) emptyState.style.display = 'block';
        }
        e.stopPropagation();
        return;
        }

        const field = e.target.closest('.form-item');
        if(field) {
        selectField(field);
        } else {
        unselectField();
        }
        });

        function getHtmlTemplate(type) {
        switch(type) {
        case 'text':
        return `<label class="form-label fw-semibold text-dark control-label">Texto Curto</label><input type="text" class="form-control bg-light text-muted" placeholder="Digite aqui..." readonly />`;
        case 'textarea':
        return `<label class="form-label fw-semibold text-dark control-label">Texto Longo</label><textarea class="form-control bg-light text-muted" rows="3" placeholder="Digite detalhes aqui..." readonly></textarea>`;
        case 'number':
        return `<label class="form-label fw-semibold text-dark control-label">Número</label><input type="number" class="form-control bg-light text-muted" placeholder="0" readonly />`;
        case 'email':
        return `<label class="form-label fw-semibold text-dark control-label">E-mail</label><input type="email" class="form-control bg-light text-muted" placeholder="exemplo@email.com" readonly />`;
        case 'select':
        return `<label class="form-label fw-semibold text-dark control-label">Lista Suspensa</label><select class="form-select bg-light text-muted" disabled><option>Opção 1</option><option>Opção 2</option><option>Opção 3</option></select>`;
        case 'checkbox':
        return `<label class="form-label fw-semibold text-dark control-label d-block mb-3">Permissões</label><div class="form-check mb-2"><input class="form-check-input" type="checkbox" checked disabled><label class="form-check-label text-muted">Opção 1 (Ler)</label></div><div class="form-check"><input class="form-check-input" type="checkbox" disabled><label class="form-check-label text-muted">Opção 2 (Escrever)</label></div>`;
        case 'radio':
        return `<label class="form-label fw-semibold text-dark control-label d-block mb-3">Género</label><div class="form-check form-check-inline"><input class="form-check-input" type="radio" checked disabled><label class="form-check-label text-muted">Masculino</label></div><div class="form-check form-check-inline"><input class="form-check-input" type="radio" disabled><label class="form-check-label text-muted">Feminino</label></div>`;
        case 'date':
        return `<label class="form-label fw-semibold text-dark control-label">Data de Nascimento</label><input type="date" class="form-control bg-light text-muted" readonly />`;
        case 'title':
        return `<h3 class="control-label mb-2 text-primary fw-bold">Informação Pessoal</h3><p class="text-secondary small mb-0">Preencha os dados abaixo</p><hr class="mt-3 mb-0 opacity-25" />`;
        case 'button':
        return `<div class="d-grid mt-2"><button class="btn btn-primary btn-lg fw-semibold" type="button" disabled>Submeter Dados</button></div>`;
        default:
        return `<label class="form-label fw-semibold text-dark control-label">Campo</label><input type="text" class="form-control bg-light" readonly />`;
        }
        }

        const propLabel = document.getElementById('propLabel');
        const propPlaceholder = document.getElementById('propPlaceholder');
        const propPlaceholderContainer = document.getElementById('propPlaceholderContainer');
        const propRequired = document.getElementById('propRequired');
        const propOptionsContainer = document.getElementById('propOptionsContainer');
        const propOptions = document.getElementById('propOptions');

        function selectField(field) {
        if(currentSelected) {
        currentSelected.classList.remove('border-primary');
        currentSelected.classList.remove('border-3');
        currentSelected.classList.add('border-secondary-subtle');
        currentSelected.querySelector('.btn-actions').classList.add('d-none');
        }
                
        currentSelected = field;
        field.classList.remove('border-secondary-subtle');
        field.classList.add('border-primary');
        field.classList.add('border-3');
        field.querySelector('.btn-actions').classList.remove('d-none');
                
        propertiesContainer.classList.remove('d-none');
        propertiesContainer.classList.add('d-block');

        const type = field.getAttribute('data-type');
        const labelEl = field.querySelector('.control-label');
        const inputEl = field.querySelector('input, textarea');

        if (type === 'button') {
        const btnEl = field.querySelector('.btn');
        propLabel.value = btnEl ? btnEl.innerText : 'Botão';
        } else {
        let cleanedName = labelEl ? labelEl.innerText.replace(' *', '') : 'Rótulo';
        propLabel.value = cleanedName;
        }
                
        if(['text', 'textarea', 'number', 'email'].includes(type) && inputEl) {
        propPlaceholderContainer.classList.remove('d-none');
        propPlaceholder.value = inputEl.getAttribute('placeholder') || '';
        } else {
        propPlaceholderContainer.classList.add('d-none');
        }

        if(!['button', 'title'].includes(type)) {
        propRequired.disabled = false;
        propRequired.checked = labelEl && labelEl.innerText.includes('*');
        } else {
        propRequired.disabled = true;
        propRequired.checked = false;
        }

        if(['select', 'radio', 'checkbox'].includes(type)) {
        propOptionsContainer.classList.remove('d-none');
        propOptionsContainer.classList.add('d-block');
        propOptions.value = "Opção 1, Opção 2, Opção 3";
        } else {
        propOptionsContainer.classList.remove('d-block');
        propOptionsContainer.classList.add('d-none');
        }
        }

        function unselectField() {
        if(currentSelected) {
        currentSelected.classList.remove('border-primary');
        currentSelected.classList.remove('border-3');
        currentSelected.classList.add('border-secondary-subtle');
        currentSelected.querySelector('.btn-actions').classList.add('d-none');
        }
        currentSelected = null;
        propertiesContainer.classList.remove('d-block');
        propertiesContainer.classList.add('d-none');
        }

        propLabel.addEventListener('input', function() {
        if(currentSelected) {
        const type = currentSelected.getAttribute('data-type');
        if (type === 'button') {
        const btnEl = currentSelected.querySelector('.btn');
        if(btnEl) btnEl.innerText = this.value;
        } else {
        const labelEl = currentSelected.querySelector('.control-label');
        if(labelEl) {
        labelEl.innerText = this.value + (propRequired.checked ? ' *' : '');
        }
        }
        }
        });

        propPlaceholder.addEventListener('input', function() {
        if(currentSelected) {
        const inputEl = currentSelected.querySelector('input, textarea');
        if(inputEl) inputEl.setAttribute('placeholder', this.value);
        }
        });

        propRequired.addEventListener('change', function() {
        if(currentSelected) {
        const labelEl = currentSelected.querySelector('.control-label');
        if(labelEl && currentSelected.getAttribute('data-type') !== 'button') {
        let text = labelEl.innerText.replace(' *', '');
        if(this.checked) text += ' *';
        labelEl.innerText = text;
        if(this.checked) {
        labelEl.innerHTML = labelEl.innerText.replace('*', '<span class="text-danger">*</span>');
        }
        }
        }
        });

        document.getElementById('btnSaveForm').addEventListener('click', function() {
        const btn = this;
        const originalContent = btn.innerHTML;
                
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Guardando...';
        btn.disabled = true;
                
        setTimeout(() => {
        btn.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i> Guardado com Sucesso!';
        btn.classList.add('bg-success', 'border-success', 'text-white');
                    
        setTimeout(() => {
        btn.innerHTML = originalContent;
        btn.classList.remove('bg-success', 'border-success', 'text-white');
        btn.disabled = false;
        }, 2500);
        }, 1200);
        });
        });
    </script>
}
