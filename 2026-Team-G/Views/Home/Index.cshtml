@{
    ViewData["Title"] = "Página Inicial";
}

<div class="container py-5">
    <div class="position-relative overflow-hidden p-5 mb-5 shadow-sm border border-light" style="background: linear-gradient(135deg, #f4faeb 0%, #ffffff 100%); border-radius: 2rem;">
        
        <div class="row align-items-center py-4 position-relative z-index-1">
            <div class="col-lg-8 mx-auto text-center">

                <h1 class="fw-bold mb-4" style="font-size: clamp(2.5rem, 4.5vw, 4rem); letter-spacing: -1.5px; line-height: 1.15; color: #1f2937;">
                    Simplifique a submissão de pedidos no <span style="color: #7cb13b;">Politécnico de Tomar</span>
                </h1>

                <p class="mx-auto mb-5 px-md-4 text-secondary" style="font-size: 1.2rem; max-width: 680px; line-height: 1.6;">
                    Envia pedidos de reserva de salas, requisição de equipamentos e preenche outros formulários administrativos de forma simples e rápida.
                </p>

                <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                    <a asp-controller="Formularios" asp-action="Index" class="btn btn-ipt-green py-3 px-4 d-flex align-items-center justify-content-center">
                        <i class="bi bi-ui-checks-grid me-2"></i>
                        Ver Formulários
                    </a>
                    <a asp-controller="Home" asp-action="HistoricoFormulariosUtilizador" class="btn btn-ipt-outline py-3 px-4 d-flex align-items-center justify-content-center">
                        <i class="bi bi-clock-history me-2"></i>
                        Histórico de Respostas
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}