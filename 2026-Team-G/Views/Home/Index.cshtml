@{
    ViewData["Title"] = "Página Inicial";
}

<div class="container-fluid px-2 px-md-4 py-4">
    <!-- Hero Wrapper with Light Purple Background -->
    <div class="position-relative overflow-hidden p-4 p-md-5 mx-auto shadow-sm" style="background-color: #f3f2fa; border-radius: 2rem; min-height: 85vh;" id="heroWrapper">
        
        <!-- Decorative bg elements -->
        <div class="position-absolute d-none d-lg-block text-primary opacity-25" style="bottom: 5%; left: 2%; transform: rotate(-15deg);">
            <i class="bi bi-flower1" style="font-size: 14rem; color: #6366f1;"></i>
        </div>
        <div class="position-absolute d-none d-lg-block text-primary opacity-25" style="top: 10%; right: 5%; transform: rotate(15deg);">
            <i class="bi bi-stars" style="font-size: 8rem; color: #6366f1;"></i>
        </div>

        <div class="row text-center pt-5 mt-4 position-relative z-index-1">
            <div class="col-12 mx-auto" style="max-width: 850px;">
                <h1 class="fw-bold mb-4" style="font-size: clamp(2.8rem, 5vw, 4.5rem); letter-spacing: -1.5px; line-height: 1.1; color: #0f172a;">
                    <span style="color: #7966f1;">Gestor de formulários online</span><br />
                    que gera mais respostas
                </h1>
                <p class="text-secondary mx-auto mb-5 px-3" style="font-size: 1.25rem; max-width: 750px; line-height: 1.6; color: #475569 !important;">
                    Cria formulários envolventes on-line ou inquéritos em segundos com o gestor do Team_G. Obtém dados, insights qualificados e relatórios em tempo real!
                </p>
            </div>
        </div>

        <!-- The White Box -->
        <div class="row justify-content-center pb-5 mb-4 position-relative z-index-1">
            <div class="col-12 mx-auto" style="max-width: 420px;">
                <div class="card border-0 shadow-lg rounded-4 p-4 text-center" id="heroCard" style="box-shadow: 0 20px 40px rgba(0,0,0,0.06) !important;">
                    <div class="card-body p-3">
                      
                        <!-- Primary Blue Button -->
                        <a asp-controller="Formularios" asp-action="Index" class="btn text-white rounded-3 w-100 py-3 mb-3 d-flex align-items-center justify-content-center fw-medium border-0 transition-all" style="background-color: #4285f4; font-size: 1.05rem;" onmouseover="this.style.backgroundColor='#2b75f3'" onmouseout="this.style.backgroundColor='#4285f4'">
                            <span class="bg-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 28px; height: 28px;">
                                <i class="bi bi-ui-checks-grid text-primary" style="font-size: 0.9rem;"></i>
                            </span>
                            Login
                        </a>
                        
                        <!-- Secondary Dark Button just to match the visual layout of forms.app -->
                        <a href="#atividade-recente" class="btn text-white rounded-3 w-100 py-3 d-flex align-items-center justify-content-center fw-medium border-0 transition-all" style="background-color: #2b2b2b; font-size: 1.05rem;" onmouseover="this.style.backgroundColor='#1a1a1a'" onmouseout="this.style.backgroundColor='#2b2b2b'">
                            <span class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 28px; height: 28px;">
                                <i class="bi bi-clock-history text-white" style="font-size: 0.9rem;"></i>
                            </span>
                            Ver Atividade Recente
                        </a>
                        
                        <div class="mt-4 text-muted small">
                            ou
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>


@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script>
        // Apply dark mode to hero wrapper
        function updateDarkMode() {
            const isDark = localStorage.getItem('darkMode') === 'true';
            const hero = document.getElementById('heroWrapper');
            const card = document.getElementById('heroCard');
            if (hero) hero.style.backgroundColor = isDark ? '#1a1a1a' : '#f3f2fa';
            if (card) card.style.backgroundColor = isDark ? '#2d2d2d' : '#ffffff';
        }
        updateDarkMode();
        
        // Also listen for toggle changes
        document.addEventListener('DOMContentLoaded', function() {
            const toggle = document.getElementById('darkModeToggle');
            if (toggle) {
                toggle.addEventListener('change', updateDarkMode);
            }
        });
    </script>
}