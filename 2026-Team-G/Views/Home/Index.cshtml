@{
    ViewData["Title"] = "Página Inicial";
}

<div class="container-fluid px-2 px-md-4 py-4">
    <!-- Hero Wrapper with Light Purple Background -->
    <div class="position-relative overflow-hidden p-4 p-md-5 mx-auto shadow-sm" style="background-color: #f3f2fa; border-radius: 2rem; min-height: 85vh;">
        
        <!-- Decorative bg elements -->
        <div class="position-absolute d-none d-lg-block text-primary opacity-25" style="bottom: 5%; left: 2%; transform: rotate(-15deg);">
            <i class="bi bi-flower1" style="font-size: 14rem; color: #6366f1;"></i>
        </div>
        <div class="position-absolute d-none d-lg-block text-primary opacity-25" style="top: 10%; right: 5%; transform: rotate(15deg);">
            <i class="bi bi-stars" style="font-size: 8rem; color: #6366f1;"></i>
        </div>

        <div class="row text-center pt-5 mt-4 position-relative z-index-1">
            <div class="col-12 mx-auto" style="max-width: 850px;">
                <h1 class="fw-bold mb-4" style="font-size: clamp(2.8rem, 5vw, 4.5rem); letter-spacing: -1.5px; line-height: 1.1; color: #0f172a;">
                    <span style="color: #7966f1;">Gestor de formulários online</span><br />
                    que gera mais respostas
                </h1>
                <p class="text-secondary mx-auto mb-5 px-3" style="font-size: 1.25rem; max-width: 750px; line-height: 1.6; color: #475569 !important;">
                    Cria formulários envolventes on-line ou inquéritos em segundos com o gestor do Team_G. Obtém dados, insights qualificados e relatórios em tempo real!
                </p>
            </div>
        </div>

        <!-- The White Box -->
        <div class="row justify-content-center pb-5 mb-4 position-relative z-index-1">
            <div class="col-12 mx-auto" style="max-width: 420px;">
                <div class="card border-0 shadow-lg rounded-4 p-4 text-center" style="box-shadow: 0 20px 40px rgba(0,0,0,0.06) !important;">
                    <div class="card-body p-3">
                      
                        <!-- Primary Blue Button -->
                        <a asp-controller="Formularios" asp-action="Index" class="btn text-white rounded-3 w-100 py-3 mb-3 d-flex align-items-center justify-content-center fw-medium border-0 transition-all" style="background-color: #4285f4; font-size: 1.05rem;" onmouseover="this.style.backgroundColor='#2b75f3'" onmouseout="this.style.backgroundColor='#4285f4'">
                            <span class="bg-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 28px; height: 28px;">
                                <i class="bi bi-ui-checks-grid text-primary" style="font-size: 0.9rem;"></i>
                            </span>
                            Login
                        </a>
                        
                        <!-- Secondary Dark Button just to match the visual layout of forms.app -->
                        <a href="#atividade-recente" class="btn text-white rounded-3 w-100 py-3 d-flex align-items-center justify-content-center fw-medium border-0 transition-all" style="background-color: #2b2b2b; font-size: 1.05rem;" onmouseover="this.style.backgroundColor='#1a1a1a'" onmouseout="this.style.backgroundColor='#2b2b2b'">
                            <span class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 28px; height: 28px;">
                                <i class="bi bi-clock-history text-white" style="font-size: 0.9rem;"></i>
                            </span>
                            Ver Atividade Recente
                        </a>
                        
                        <div class="mt-4 text-muted small">
                            ou
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Atividade Recente Section -->
<div id="atividade-recente" class="container mt-5 pt-4">
    <div class="d-flex justify-content-between align-items-end mb-4 px-2">
        <div>
            <h3 class="fw-bold text-dark m-0">Atividade Recente</h3>
            <p class="text-muted small mt-1 mb-0">Os últimos documentos atualizados no sistema.</p>
        </div>
        <a asp-controller="Formularios" asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill px-3 py-2 fw-medium">
            Ver todo o histórico
        </a>
    </div>
    
    <div class="card border-0 shadow-sm rounded-4 mt-3 mb-5">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th class="ps-4 py-3 border-0 rounded-top-start-4">Documento</th>
                            <th class="py-3 border-0">Estado</th>
                            <th class="py-3 border-0">Data de Atualização</th>
                            <th class="text-end pe-4 py-3 border-0 rounded-top-end-4">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3 text-primary">
                                        <i class="bi bi-file-earmark-text fs-4"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-dark">Inquérito de Satisfação</h6>
                                        <small class="text-muted"><i class="bi bi-person-circle me-1"></i> Criado por Admin</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2 border border-success border-opacity-25" style="font-weight: 600;"><i class="bi bi-check-circle-fill me-1"></i> Ativo</span>
                            </td>
                            <td>
                                <span class="text-secondary fw-medium"><i class="bi bi-calendar-event me-2 text-muted"></i>16 Abr, 2026</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-controller="Formularios" asp-action="Details" asp-route-id="1" class="btn btn-sm btn-light border text-decoration-none fw-medium d-inline-flex align-items-center">
                                    <i class="bi bi-eye-fill me-2 text-primary"></i> Detalhes
                                </a>
                            </td>
                        </tr>
                        
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-info bg-opacity-10 p-2 rounded-3 me-3 text-info">
                                        <i class="bi bi-file-earmark-person fs-4"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-dark">Avaliação de Desempenho</h6>
                                        <small class="text-muted"><i class="bi bi-person-circle me-1"></i> Criado por RH</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary px-3 py-2 border border-secondary border-opacity-25" style="font-weight: 600;"><i class="bi bi-clock-fill me-1"></i> Rascunho</span>
                            </td>
                            <td>
                                <span class="text-secondary fw-medium"><i class="bi bi-calendar-event me-2 text-muted"></i>14 Abr, 2026</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-controller="Formularios" asp-action="Details" asp-route-id="2" class="btn btn-sm btn-light border text-decoration-none fw-medium d-inline-flex align-items-center">
                                    <i class="bi bi-eye-fill me-2 text-primary"></i> Detalhes
                                </a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}