@model IEnumerable<_2026_Team_G.Models.Formulario>

@{
    ViewData["Title"] = "Componentes de Formulário";
}

<style>
    .num-step {
        width: 35px;
        height: 35px;
        background-color: #0d6efd;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-weight: bold;
        margin-right: 15px;
        flex-shrink: 0;
    }

    .pin-container {
        display: flex;
        gap: 8px;
    }

    .pin-input {
        width: 45px;
        height: 45px;
        text-align: center;
        font-size: 1.2rem;
        font-weight: bold;
        border: 2px solid #dee2e6;
        border-radius: 6px;
        background-color: #fff;
    }

    .pin-input:focus {
        border-color: #0d6efd;
        outline: none;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
    }

    .pin-input::-webkit-inner-spin-button,
    .pin-input::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>

<div class="container mt-5 pb-5">
    <div class="border-bottom mb-4 pb-3">
        <h1 class="display-5 fw-bold text-primary">@ViewData["Title"]</h1>
        <p class="text-secondary">Template de componentes carregados dinamicamente da Base de Dados</p>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 offset-md-3">
            <div class="input-group shadow-sm">
                <input type="text" id="searchComponent" class="form-control border-start-0 ps-0" placeholder="Filtrar componente..">
            </div>
        </div>
    </div>

    <div class="row g-4" id="componentsGrid">
        @{
            int contador = 1;
        }

        @if (ViewBag.ComponentesDisponiveis != null)
        {
            @foreach (_2026_Team_G.Models.Component comp in ViewBag.ComponentesDisponiveis)
            {
                var nomeLower = comp.name.ToLower();
                var cssClass = comp.componentClass ?? "form-control";

                <div class="col-md-6 component-card-wrapper" data-name="@nomeLower">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="num-step">@contador.ToString("D2")</div>
                                <h5 class="card-title fw-bold m-0">@comp.name</h5>
                            </div>

                            @* RENDERIZAÇÃO BASEADA NO NOME QUE VEM DA DB *@
                            @if (nomeLower == "numero")
                            {
                                <p class="small text-muted">sublabel</p>
                                <div class="pin-container">
                                    @* Mantém a classe pin-input injetada da BD *@
                                    <input type="number" class="@cssClass" oninput="if(this.value.length > 1) this.value = this.value.slice(0, 1);" />
                                    <input type="number" class="@cssClass" oninput="if(this.value.length > 1) this.value = this.value.slice(0, 1);" />
                                    <input type="number" class="@cssClass" oninput="if(this.value.length > 1) this.value = this.value.slice(0, 1);" />
                                    <input type="number" class="@cssClass" oninput="if(this.value.length > 1) this.value = this.value.slice(0, 1);" />
                                </div>
                            }
                            else if (nomeLower == "texto" || nomeLower == "text box")
                            {
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">label bold</label>
                                    <input type="text" class="@cssClass" placeholder="insira o nome" />
                                </div>
                            }
                            else if (nomeLower == "combo box" || nomeLower == "combobox")
                            {
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">label bold</label>
                                    <select class="form-select @cssClass">
                                        <option selected disabled>Escolha uma opção...</option>
                                        <option>a</option>
                                        <option>b</option>
                                        <option>c</option>
                                    </select>
                                </div>
                            }
                            else if (nomeLower == "check box switch")
                            {
                                <div class="@cssClass mb-2">
                                    <input class="form-check-input" type="checkbox" id="sw_@contador" checked>
                                    <label class="form-check-label ms-2" for="sw_@contador">a</label>
                                </div>
                            }
                            else if (nomeLower == "check box")
                            {
                                <div class="@cssClass">
                                    <input class="form-check-input" type="checkbox" id="ck_@contador">
                                    <label class="form-check-label ms-2" for="ck_@contador">b</label>
                                </div>
                            }
                            else if (nomeLower == "label")
                            {
                                <p class="small text-muted">SubLabel placeholder</p>
                                <label class="@cssClass">Label bold</label>
                            }
                            else if (nomeLower == "assinatura")
                            {
                                <div class="mt-4 pt-2">
                                    <div style="border-bottom: 2px solid #333; width: 100%; min-height: 40px;">
                                        <input type="text" class="@cssClass" disabled placeholder="Zona de Assinatura" />
                                    </div>
                                </div>
                            }
                            else
                            {
                                @* Fallback de segurança para qualquer outro componente *@
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">@comp.name</label>
                                    <input type="text" class="@cssClass" />
                                </div>
                            }
                        </div>
                    </div>
                </div>

                {
                    contador++;
                }
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="bi bi-box-seam fs-1 d-block mb-3"></i>
                Nenhum componente foi carregado da base de dados.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Filtro de pesquisa por texto em JavaScript nativo
        document.getElementById('searchComponent').addEventListener('input', function () {
            const filter = this.value.toLowerCase().trim();
            const cards = document.querySelectorAll('.component-card-wrapper');

            cards.forEach(card => {
                const name = card.getAttribute('data-name');
                if (name.includes(filter)) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    </script>
}